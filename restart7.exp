#!/usr/bin/expect -f
set timeout 300
spawn ssh -o StrictHostKeyChecking=no ubuntu@106.54.38.207 "rm -f /home/ubuntu/app.log; cd /home/ubuntu && nohup env PATH=/home/ubuntu/.local/bin:/usr/local/bin:/usr/bin:/bin LD_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu /usr/bin/python3 /home/ubuntu/main.py > /home/ubuntu/app.log 2>&1 & echo 'PID='\$!; sleep 15 && cat /home/ubuntu/app.log && echo '===' && curl -s http://localhost:8000/"
expect "password:" { send "Gtt@123456789\r" }
expect eof
