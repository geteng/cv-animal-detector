#!/usr/bin/expect -f
set timeout 60
spawn ssh -o StrictHostKeyChecking=no ubuntu@106.54.38.207 "pkill -f 'python3 main.py' 2>/dev/null; rm -f /home/ubuntu/app.log; export PATH=\$HOME/.local/bin:\$PATH; cd /home/ubuntu && nohup python3 main.py > /home/ubuntu/app.log 2>&1 & sleep 10 && cat /home/ubuntu/app.log"
expect "password:" { send "Gtt@123456789\r" }
expect eof
