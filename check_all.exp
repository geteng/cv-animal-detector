#!/usr/bin/expect -f
set timeout 15
spawn ssh -o StrictHostKeyChecking=no ubuntu@106.54.38.207 "sudo systemctl status nginx --no-pager | head -5; echo '==='; ps aux | grep 'python3 main' | grep -v grep; echo '==='; curl -s http://127.0.0.1:8000/; echo '==='; sudo tail -5 /var/log/nginx/error.log"
expect "password:" { send "Gtt@123456789\r" }
expect eof
