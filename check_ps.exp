spawn ssh -o StrictHostKeyChecking=no ubuntu@106.54.38.207 "ps aux | grep 'docker build' | grep -v grep; echo '---'; wc -c /home/ubuntu/build.log 2>/dev/null; echo '---'; cat /home/ubuntu/build.log 2>/dev/null | wc -l"
