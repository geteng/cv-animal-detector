#!/usr/bin/expect -f
set timeout 60
spawn ssh -o StrictHostKeyChecking=no ubuntu@106.54.38.207 "kill \$(pgrep -f 'python3 /home/ubuntu/main.py') 2>/dev/null; sleep 2; rm -f /home/ubuntu/app.log; nohup env PATH=/home/ubuntu/.local/bin:/usr/local/bin:/usr/bin:/bin LD_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu /usr/bin/python3 /home/ubuntu/main.py > /home/ubuntu/app.log 2>&1 & sleep 10 && tail -3 /home/ubuntu/app.log && echo '===' && curl -s https://127.0.0.1/health"
expect "password:" { send "Gtt@123456789\r" }
expect eof
