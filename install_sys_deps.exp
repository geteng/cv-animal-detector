#!/usr/bin/expect -f
set timeout 60
spawn ssh -o StrictHostKeyChecking=no ubuntu@106.54.38.207 "sudo apt-get update -qq && sudo apt-get install -y -qq libgl1-mesa-glx libglib2.0-0 libsm6 libxext6 libxrender1 libgomp1 2>&1 | tail -5"
expect "password:" { send "Gtt@123456789\r" }
expect {
  "password for ubuntu:" { send "Gtt@123456789\r"; exp_continue }
  eof
}
