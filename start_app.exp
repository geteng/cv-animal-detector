#!/usr/bin/expect -f
set timeout 30
spawn ssh -o StrictHostKeyChecking=no ubuntu@106.54.38.207 "cp /home/ubuntu/cv-animal-detector/main.py /home/ubuntu/main.py && mkdir -p /home/ubuntu/.local/bin && echo 'export PATH=\$HOME/.local/bin:\$PATH' >> /home/ubuntu/.bashrc && export PATH=\$HOME/.local/bin:\$PATH && cd /home/ubuntu && nohup python3 main.py > /home/ubuntu/app.log 2>&1 & sleep 3 && curl -s http://localhost:8000/"
